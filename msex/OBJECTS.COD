;|*** FOOD("orange",              10, 1,  2, 0, VEGGY,  80, CLR_ORANGE),
;|*** FOOD("mushroom",             1, 1,  5, 0, VEGGY,  90, CLR_BLACK),
;|*** FOOD("melon",                9, 1,  5, 0, VEGGY, 100, CLR_BRIGHT_GREEN),
