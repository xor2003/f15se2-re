;|***     int start,
;|***     int ch,
;|***     int lo,
;|***     int melo,
;|***     int me,
;|***     int mehi,
;|***     int hi);
;|*** static void addCycle(int lo, int melo, int me, int mehi, int hi);
;|*** static void buildPalette(void);
;|*** static void levelUp(void);
;|*** static void printPalette(int levelup);
;|*** static void vgapal(int levelup);
